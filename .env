# Observability Playground Environment Variables

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin123

# Grafana OnCall
GRAFANA_ONCALL_SECRET_KEY=my-super-secret-key-change-in-prod
ONCALL_DB_USER=oncall
ONCALL_DB_PASSWORD=oncall123
ONCALL_DB_NAME=oncall
ONCALL_REDIS_URI=redis://redis:6379/0
RABBITMQ_USER=rabbitmq
RABBITMQ_PASS=rabbitmq123

# PostgreSQL (OnCall)
POSTGRES_USER=oncall
POSTGRES_PASSWORD=oncall123
POSTGRES_DB=oncall

# OTel
OTEL_SERVICE_NAME=sample-app
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
